APP_ENV=local
APP_PUBLIC_URL=http://localhost:8080
SUBSCRIPTION_PATH_SECRET=L0mENeiofHjdxC57
HTTP_ADDR=:8080

# Локальный запуск Go через make run-api / run-bot / run-worker.
# PostgreSQL живет в Docker, наружу доступен через port-forwarder:
# 127.0.0.1:5433 -> sakeofher-postgres:5432
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_USER=sakeofher
POSTGRES_PASSWORD=sakeofher_password
POSTGRES_DB=sakeofher
POSTGRES_SSL_MODE=disable
POSTGRES_MAX_CONNS=20
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=1h
POSTGRES_MAX_CONN_IDLE_TIME=30m
POSTGRES_HEALTH_CHECK_PERIOD=1m
POSTGRES_CONNECT_TIMEOUT=5s
POSTGRES_QUERY_TIMEOUT=5s

JWT_SECRET=change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=sakeofher_bot
TELEGRAM_ADMIN_IDS=

# Telegram OAuth 2.0 / OpenID Connect. Values are issued in BotFather → Bot Settings → Web Login.
TELEGRAM_OAUTH_CLIENT_ID=
TELEGRAM_OAUTH_CLIENT_SECRET=
TELEGRAM_OAUTH_REDIRECT_URL=http://localhost:5173/api/v1/auth/telegram/oauth/callback
TELEGRAM_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:5173/auth/success
TELEGRAM_OAUTH_TIMEOUT=15s

REMNAWAVE_BASE_URL=https://panel.example.com
REMNAWAVE_API_TOKEN=
REMNAWAVE_TIMEOUT=15s

TRIBUTE_API_KEY=
TRIBUTE_WEBHOOK_SECRET_PATH=tribute-secret
TRIBUTE_TIMEOUT=15s

CRYPTOBOT_API_TOKEN=
CRYPTOBOT_WEBHOOK_SECRET_PATH=cryptobot-secret
CRYPTOBOT_TIMEOUT=15s

WORKER_SYNC_USAGE_INTERVAL=1h
WORKER_EXPIRE_INTERVAL=1h
WORKER_DELETE_DISABLED_INTERVAL=24h
WORKER_RESET_TRAFFIC_INTERVAL=1h
WORKER_NOTIFY_INTERVAL=24h
WORKER_RETRY_ACTIVATION_INTERVAL=5m
