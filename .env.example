POSTGRES_QUERY_TIMEOUT=10s

JWT_SECRET=put_long_random_64_plus_chars_secret_here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

TELEGRAM_BOT_TOKEN=put_new_rotated_bot_token_here
